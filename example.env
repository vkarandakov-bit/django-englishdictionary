# Для PostgreSQL раскомментируйте и заполните:
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=english_card

# Если DB_HOST не задан, используется SQLite (db.sqlite3) — удобно для локального запуска.

SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
